#!/usr/bin/env python3
"""
Wrapper around ~/.local/bin/groq-voice that writes status to
/tmp/groq-voice-status so the GNOME Shell extension can display
a visual indicator in the top bar.

Usage: replace the hotkey command groq-voice → groq-voice-wrapper
The original script is never modified.
"""
import json
import os
import subprocess
import sys
import time
from datetime import date
from pathlib import Path

PIDFILE = "/tmp/groq-voice.pid"
START_FILE = "/tmp/groq-voice-start"
LIMIT_FILE = "/tmp/groq-voice-limit"
STATUS_FILE = "/tmp/groq-voice-status"
STATS_FILE = Path.home() / ".local/share/groq-voice/stats.json"
ORIGINAL = os.path.expanduser("~/.local/bin/groq-voice")
SHIMS_DIR = os.path.expanduser("~/.local/lib/groq-voice-shims")

TAIL_DELAY = 1.5        # seconds to keep recording after stop hotkey
MAX_RECORDING_SECS = 5 * 60  # safeguard: auto-stop after this many seconds

# Prepend shims dir so fake notify-send intercepts calls from the original script
os.environ["PATH"] = SHIMS_DIR + ":" + os.environ.get("PATH", "")


def write_status(status: str) -> None:
    try:
        with open(STATUS_FILE, "w") as f:
            f.write(status)
    except OSError:
        pass


def write_stats(duration_secs: int) -> None:
    today = date.today().isoformat()
    stats: dict = {}
    if STATS_FILE.exists():
        try:
            stats = json.loads(STATS_FILE.read_text())
        except Exception:
            pass
    if today not in stats:
        stats[today] = {"requests": 0, "seconds": 0}
    stats[today]["requests"] += 1
    stats[today]["seconds"] += max(0, duration_secs)
    STATS_FILE.parent.mkdir(parents=True, exist_ok=True)
    STATS_FILE.write_text(json.dumps(stats, indent=2))


def run_watchdog() -> None:
    """Detached process: auto-stop recording if MAX_RECORDING_SECS is exceeded."""
    time.sleep(MAX_RECORDING_SECS)
    if not os.path.exists(PIDFILE):
        return  # already stopped normally — nothing to do
    write_status("recognizing")
    try:
        subprocess.run([ORIGINAL])
        write_stats(MAX_RECORDING_SECS)
    finally:
        write_status("idle")
        for f in (START_FILE, LIMIT_FILE):
            try:
                os.remove(f)
            except OSError:
                pass


def main():
    # Internal mode: launched as background watchdog on recording start
    if len(sys.argv) > 1 and sys.argv[1] == "--watchdog":
        run_watchdog()
        return

    if os.path.exists(PIDFILE):
        # Recording is already active — wait for tail, then stop and transcribe
        duration = 0
        try:
            with open(START_FILE) as f:
                duration = int(time.time() - float(f.read()) + TAIL_DELAY)
        except Exception:
            pass

        time.sleep(TAIL_DELAY)  # keep recording so last words are captured
        write_status("recognizing")
        try:
            subprocess.run([ORIGINAL] + sys.argv[1:])
            write_stats(duration)
        finally:
            write_status("idle")
            for f in (START_FILE, LIMIT_FILE):
                try:
                    os.remove(f)
                except OSError:
                    pass
    else:
        # No recording active — start one
        try:
            with open(START_FILE, "w") as f:
                f.write(str(time.time()))
        except OSError:
            pass
        write_status("recording")

        # Tell the extension what the recording limit is (for warning pulse)
        try:
            with open(LIMIT_FILE, "w") as f:
                f.write(str(MAX_RECORDING_SECS))
        except OSError:
            pass

        # Launch watchdog as detached background process
        subprocess.Popen(
            [sys.executable, os.path.abspath(__file__), "--watchdog"],
            start_new_session=True,
            close_fds=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )

        subprocess.run([ORIGINAL] + sys.argv[1:])
        # Status intentionally stays "recording" until next invocation


if __name__ == "__main__":
    main()
